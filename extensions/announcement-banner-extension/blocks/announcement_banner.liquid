{% assign announcement = shop.metafields.my_app.announcement.value %}

{% if announcement != blank %}

<div id="announcement-banner">
  <div class="announcement-content">
    <span class="announcement-icon">🚀</span>
    <span class="announcement-text">{{ announcement }}</span>
  </div>
</div>

<style>
#announcement-banner {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 99999;
  background: linear-gradient(135deg, #ff512f, #dd2476);
  color: #ffffff;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
  animation: slideDown 0.4s ease-out;
}

.announcement-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 14px 20px;
  font-size: 18px;
  font-weight: 600;
  letter-spacing: 0.3px;
}

.announcement-icon {
  font-size: 24px;
  animation: bounce 2s infinite;
}

.announcement-text {
  text-transform: uppercase;
}

body {
  padding-top: 60px;
}

@keyframes slideDown {
  from {
    transform: translateY(-100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4px);
  }
}

@media (max-width: 768px) {
  .announcement-content {
    font-size: 15px;
    padding: 12px;
  }

  .announcement-icon {
    font-size: 20px;
  }

  body {
    padding-top: 55px;
  }
}
</style>

{% endif %}

{% schema %}
{
"name": "Announcement Banner",
"target": "body"
}
{% endschema %}
